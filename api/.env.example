# App
ENVIRONMENT=development
DEBUG=true

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/datajud_monitor

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# API Pública DataJud (CNJ)
# Chave vigente sempre em: https://datajud-wiki.cnj.jus.br/api-publica/acesso/
# ATENÇÃO: pode ser rotacionada pelo CNJ a qualquer momento, sem aviso formal.
DATAJUD_API_KEY=
DATAJUD_BASE_URL=https://api-publica.datajud.cnj.jus.br

# Agendamento / rate limit
CONSULTA_DIARIA_HORA_UTC=6
DATAJUD_RATE_LIMIT_PER_MINUTE=25
